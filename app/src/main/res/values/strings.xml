    <string name="info_section_stack_body">Android app built with Kotlin, Jetpack Compose (Material 3), Navigation Compose, Room, DataStore and Hilt dependency injection.</string>
    <string name="info_section_libraries_title">Libraries</string>
    <string name="info_section_libraries_body">Core AndroidX, Lifecycle, Activity Compose, Navigation Compose, Room, DataStore Preferences, Hilt Android, Hilt Navigation Compose, JUnit and Compose UI test dependencies.</string>
