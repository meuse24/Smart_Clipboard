    <string name="help_section_getting_started_title">Getting Started</string>
    <string name="help_section_getting_started_body">Use the home screen to actively import your current clipboard content. Then open History to inspect, search and reuse entries.</string>
    <string name="help_section_import_title">Active Import</string>
    <string name="help_section_import_body">Tap "Import Clipboard Now" to read the current clipboard while the app is in the foreground. This keeps the behavior explicit and predictable.</string>
    <string name="help_section_history_title">History</string>
    <string name="help_section_history_body">History stores entries locally in Room. Use the search field to filter by content, source app or detected type.</string>
    <string name="help_section_quick_actions_title">Quick Actions</string>
    <string name="help_section_quick_actions_body">For recognized types, actions are shown directly in History and Detail: open URLs, dial phone numbers and compose emails.</string>
    <string name="help_section_privacy_title">Privacy</string>
    <string name="help_section_privacy_body">Sensitive content can be masked in previews. OTP entries are not persisted by default. Retention settings control automatic cleanup of older entries.</string>
    <string name="help_section_settings_title">Settings</string>
    <string name="help_section_settings_body">Open Settings from the menu to configure appearance, privacy behavior, history size and retention period.</string>
    <string name="help_section_tile_title">Quick Settings Tile</string>
    <string name="help_section_tile_body">You can add the app’s Quick Settings tile and trigger a fast import from the system shade.</string>
    <string name="help_section_troubleshooting_title">Troubleshooting</string>
    <string name="help_section_troubleshooting_body">If imports do not appear, ensure clipboard has text content, then import again from Home. Also verify retention settings are not too aggressive.</string>

