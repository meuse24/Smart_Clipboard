    <string name="help_section_getting_started_title">Getting Started</string>
    <string name="help_section_getting_started_body">Use the Home tab to import your current clipboard content. Switch to History via the bottom navigation to inspect, search and reuse entries.</string>
    <string name="help_section_import_title">Active Import</string>
    <string name="help_section_import_body">Tap "Import Clipboard Now" to read the current clipboard while the app is in the foreground. This keeps the behavior explicit and predictable.</string>
    <string name="help_section_history_title">History</string>
    <string name="help_section_history_body">History stores entries locally. Use the search field to filter by content, source app or detected type.</string>
    <string name="help_section_content_types_title">Supported Content Types</string>
    <string name="help_section_content_types_body">The app recognizes and handles: URLs, Phone Numbers, E-Mail addresses, OTP codes, IBANs, JSON, Code Snippets, Colors (hex / rgb / hsl), Geo Coordinates, Images, Files and plain text.</string>
    <string name="help_section_quick_actions_title">Quick Actions</string>
    <string name="help_section_quick_actions_body">Recognized types get direct actions in History and Detail: open URLs in the browser, dial numbers, compose emails, open geo coordinates in Maps, open local files and preview images or color swatches.</string>
    <string name="help_section_privacy_title">Privacy</string>
    <string name="help_section_privacy_body">Sensitive content can be masked in previews. OTP entries are not persisted by default. Retention settings control automatic cleanup of older entries including their media files.</string>
    <string name="help_section_settings_title">Settings</string>
    <string name="help_section_settings_body">Open Settings via the bottom navigation to configure appearance, privacy behavior, history size and retention period.</string>
    <string name="help_section_tile_title">Quick Settings Tile</string>
    <string name="help_section_tile_body">You can add the app\'s Quick Settings tile and trigger a fast import from the system shade.</string>
    <string name="help_section_troubleshooting_title">Troubleshooting</string>
    <string name="help_section_troubleshooting_body">If imports do not appear, ensure the clipboard has content, then import again from the Home tab. Check that retention settings are not too aggressive. Media imports require the clipboard to hold an image or file URI.</string>

