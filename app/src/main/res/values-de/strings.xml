    <string name="info_section_stack_title">Tech-Stack</string>
    <string name="info_section_stack_body">Android-App mit Kotlin, Jetpack Compose (Material 3), Navigation Compose, Room, DataStore, Hilt Dependency Injection und Coil für das Laden von Bildern.</string>
    <string name="info_section_libraries_title">Bibliotheken</string>
    <string name="info_section_libraries_body">Core AndroidX, Lifecycle, Activity Compose, Navigation Compose, Room, DataStore Preferences, Hilt Android, Hilt Navigation Compose, Coil Compose, JUnit und Compose UI-Test-Abhängigkeiten.</string>
